+];
+
+// ── Trajectories [c0 (T0), c11 (last)] — actual T5 is the anchor ─────
+// Designed for visual interest: rank inversions, rising/falling teams
+const TRAJ = {
+  'vpack20':                    [1002500, 1022500], // #3 → #1 → #1  Rising star
+  'temshik_trader':             [1006000, 1003500], // #1 → #2 → #2  Lost lead
+  'ras0087':                    [1000100, 1001000], // #9 → #3 → #3  Slow climber
+  'mkhmzr':                     [1000050, 999800],  // #10→ #4 → #5  Nearly flat
+  'liken17':                    [1000020, 999900],  // #11→ #5 → #6  Nearly flat
+  'moexflipper':                [1000010, 999980],  // #12→ #6 → #4  Slight rise
+  'Belkovskyy':                 [1000500, 999500],  // #7 → #7 → #7  Stable
+  'stasvinokur':                [1001000, 998300],  // #6 → #8 → #8  Gradual slip
+  'mail10102005':               [1001500, 997000],  // #5 → #9 → #9  Slipping
+  'dgalimov560':                [1000500, 995000],  // #8 → #10→ #10 Slipping
+  'pavel':                      [998000,  991000],  // #13→ #11→ #11 Stable middle
+  'antsev.itmo':                [1003000, 988500],  // #2 → #12→ #12 Dramatic drop!
+  'piledreke':                  [997000,  989500],  // #14→ #13→ #12 Slight rise
+  'tialgo':                     [996000,  988000],  // #15→ #14→ #13 Slight rise
+  'romalevints':                [1002000, 983000],  // #4 → #15→ #16 Dramatic drop!
+  'klevin3701':                 [997000,  985000],  // #15→ #16→ #15 Stable
+  'trader228':                  [995000,  982000],  // #16→ #17→ #17 Stable
+  'and159753000000000000000000':[994000,  977000],  // #17→ #18→ #18
+  'ivaldepabloadrian':          [993500,  975000],  // #18→ #19→ #19
+  'a.strachenkov':              [988000,  971000],  // #20→ #20→ #20
+  'serfetto':                   [985000,  967000],  // #21→ #21→ #21
+  'h.timur.alisherovich':       [980000,  959000],  // #22→ #22→ #22 Always drops
+};
+
+// ── Snapshot timestamps ───────────────────────────────────────────────
+const SNAPS = [
+  {ts:'2026-05-20T10:30:00+03:00', label:'20 мая 2026, 10:30'},
+  {ts:'2026-05-20T12:00:00+03:00', label:'20 мая 2026, 12:00'},
+  {ts:'2026-05-20T14:00:00+03:00', label:'20 мая 2026, 14:00'},
+  {ts:'2026-05-20T16:00:00+03:00', label:'20 мая 2026, 16:00'},
+  {ts:'2026-05-20T18:00:00+03:00', label:'20 мая 2026, 18:00'},
+  {ts:'2026-05-21T10:24:00+03:00', label:'21 мая 2026, 10:24'},  // <── actual data (idx=5)
+  {ts:'2026-05-21T12:00:00+03:00', label:'21 мая 2026, 12:00'},
+  {ts:'2026-05-21T14:00:00+03:00', label:'21 мая 2026, 14:00'},
+  {ts:'2026-05-21T16:00:00+03:00', label:'21 мая 2026, 16:00'},
+  {ts:'2026-05-21T18:00:00+03:00', label:'21 мая 2026, 18:00'},
+  {ts:'2026-05-22T10:00:00+03:00', label:'22 мая 2026, 10:00'},
+  {ts:'2026-05-22T12:00:00+03:00', label:'22 мая 2026, 12:00'},
+];
+const REF = 5;   // index of actual snapshot
+const N   = SNAPS.length;
+
+// ── Helpers ───────────────────────────────────────────────────────────
+function snapId(ts) {
+  // "2026-05-20T10:30:00+03:00" → "20260520T1030"
+  return ts.slice(0,4)+ts.slice(5,7)+ts.slice(8,10)+'T'+ts.slice(11,13)+ts.slice(14,16);
+}
+
+// Deterministic noise in [-amp, +amp] seeded by (captain, idx)
+function dnoise(captain, idx, amp) {
+  let h = idx * 1999;
+  for (let i = 0; i < captain.length; i++) h = (h * 31 + captain.charCodeAt(i)) & 0x7fffffff;
+  h = (h ^ (h >>> 16)) & 0x7fffffff;
+  return ((h % 2000) / 2000 - 0.5) * 2 * amp;
+}
+
+// Smooth step: starts slow, ends slow (S-curve between 0 and 1)
+function smooth(t) { return t * t * (3 - 2 * t); }
+
+// Capital at step idx for a given team
+function capitalAt(captain, idx) {
+  const ae   = ACTUAL.find(x => x.captain === captain);
+  const cRef = ae.capital;
+  const [c0, cEnd] = TRAJ[captain];
+
+  let base;
+  if (idx === REF) return cRef;  // exact anchor
+  if (idx < REF) {
+    const t = smooth(idx / REF);
+    base = Math.round(c0 + (cRef - c0) * t);
+    // noise: up to ±500 in the middle, 0 at endpoints
+    const noiseAmp = 500 * Math.sin(Math.PI * idx / REF);
+    base += Math.round(dnoise(captain, idx, noiseAmp));
+  } else {
+    const t = smooth((idx - REF) / (N - 1 - REF));
+    base = Math.round(cRef + (cEnd - cRef) * t);
+    const noiseAmp = 400 * Math.sin(Math.PI * (idx - REF) / (N - 1 - REF));
+    base += Math.round(dnoise(captain, idx + 100, noiseAmp));
+  }
+  return base;
+}
+
+// Compute activity string based on snapshot day and reference date
+function activityFor(idx) {
+  // Snapshots 10-11 = May 22 ("today" from that day's POV)
+  // Snapshots 5-9  = May 21
+  // Snapshots 0-4  = May 20
+  return 'today';  // all mock points are "active"
+}
+
+// Scale an auxiliary field proportionally to timeline progress
+function scaleTo(base, idx) {
+  const t = idx <= REF
+    ? 0.2 + 0.8 * (idx / REF)          // ramps up 20%→100% by T5
+    : 1.0 + 0.15 * ((idx - REF) / (N - 1 - REF));  // grows slightly after
+  return Math.round(base * t);
+}
+
+// ── Build snapshot data ───────────────────────────────────────────────
+const snapData = SNAPS.map((s, idx) => {
+  const sid = snapId(s.ts);
+  // Compute all capitals, then rank
+  const caps = ACTUAL.map(ae => ({ captain: ae.captain, capital: capitalAt(ae.captain, idx) }));
+  caps.sort((a, b) => b.capital - a.capital);
+  const rankMap = {};
+  caps.forEach((c, i) => { rankMap[c.captain] = i + 1; });
+  return { sid, s, idx, rankMap,
+    capitalMap: Object.fromEntries(caps.map(c => [c.captain, c.capital])) };
+});
+
+// ── Build timeseries.json ─────────────────────────────────────────────
+const ts = {
+  last_updated:      SNAPS[N-1].ts,
+  last_snapshot_id:  snapId(SNAPS[N-1].ts),
+  competition:       'moex-ai-agent',
+  snapshots: SNAPS.map((s, idx) => {
+    // IMOEX benchmark: 980000 at T0, 974028 at T5, 970500 at T11
+    const bm = idx <= REF
+      ? Math.round(980000 + (974028 - 980000) * (idx / REF))
+      : Math.round(974028 + (970500 - 974028) * ((idx - REF) / (N - 1 - REF)));
+    return {
+      sid:                snapId(s.ts),
+      timestamp:          s.ts,
+      label:              s.label,
+      total_participants: 47,
+      benchmark_capital:  bm,
+    };
+  }),
+  teams: {},
+};
+
+ACTUAL.forEach(ae => {
+  ts.teams[ae.captain] = {
+    team:    ae.team,
+    history: snapData.map(({ sid, idx, rankMap, capitalMap }) => ({
+      sid,
+      rank:       rankMap[ae.captain],
+      capital:    capitalMap[ae.captain],
+      commission: scaleTo(ae.commission, idx),
+      load_pct:   ae.load_pct,
+      days:       Math.max(1, Math.round(ae.days * (idx <= REF ? (0.3 + 0.7 * idx / REF) : (1 + 0.25 * (idx - REF) / (N-1-REF))))),
+      trades:     scaleTo(ae.trades, idx),
+      turnover:   scaleTo(ae.turnover, idx),
+      activity:   activityFor(idx),
+    })),
+  };
+});
+
+// ── Build latest.json (T11, May 22 12:00) ─────────────────────────────
+const last = snapData[N - 1];
+const latestEntries = ACTUAL
+  .map(ae => ({
+    rank:       last.rankMap[ae.captain],
+    team:       ae.team,
+    captain:    ae.captain,
+    capital:    last.capitalMap[ae.captain],
+    commission: scaleTo(ae.commission, N-1),
+    load_pct:   ae.load_pct,
+    days:       ae.days + 2,
+    trades:     scaleTo(ae.trades, N-1),
+    turnover:   scaleTo(ae.turnover, N-1),
+    activity:   'today',
+  }))
+  .sort((a, b) => a.rank - b.rank);
+
+const latest = {
+  snapshot_id:        snapId(SNAPS[N-1].ts),
+  timestamp:          SNAPS[N-1].ts,
+  label:              SNAPS[N-1].label,
+  total_participants: 47,
+  competition:        'moex-ai-agent',
+  source:             'mock',
+  benchmark:          { name: 'IMOEX', capital: ts.snapshots[N-1].benchmark_capital },
+  entries:            latestEntries,
+};
+
+// ── Write files ───────────────────────────────────────────────────────
+const TS_PATH     = path.join(ROOT, 'data', 'timeseries.json');
+const LATEST_PATH = path.join(ROOT, 'data', 'snapshots', 'latest.json');
+
+fs.writeFileSync(TS_PATH,     JSON.stringify(ts, null, 2));
+fs.writeFileSync(LATEST_PATH, JSON.stringify(latest, null, 2));
+
+// ── Report ─────────────────────────────────────────────────────────────
+console.log('\n✅ Generated:');
+console.log(`  ${TS_PATH}`);
+console.log(`  ${LATEST_PATH}`);
+
+console.log('\n📸 Snapshots:');
+ts.snapshots.forEach(s => console.log(`  ${s.sid}  ${s.label}`));
+
+console.log('\n🏆 T0 (May 20, 10:30) ranking:');
+const t0data = snapData[0];
+ACTUAL
+  .map(ae => ({ name: ae.team, rank: t0data.rankMap[ae.captain], cap: t0data.capitalMap[ae.captain] }))
+  .sort((a,b) => a.rank - b.rank)
+  .slice(0,5)
+  .forEach(x => console.log(`  #${x.rank} ${x.name}  ${x.cap.toLocaleString()}`));
+
+console.log('  ...');
+
+console.log('\n🏆 T11 (May 22, 12:00) ranking:');
+latestEntries.slice(0,5).forEach(x =>
+  console.log(`  #${x.rank} ${x.team}  ${x.capital.toLocaleString()}`)
+);
+console.log('  ...');
+
+console.log('\n📈 Notable rank changes (T0 → T11):');
+ACTUAL.forEach(ae => {
+  const r0 = t0data.rankMap[ae.captain];
+  const r11 = last.rankMap[ae.captain];
+  const d = r0 - r11;  // positive = improved
+  if (Math.abs(d) >= 5) {
+    const arrow = d > 0 ? `▲${d}` : `▼${Math.abs(d)}`;
+    console.log(`  ${ae.team}: #${r0} → #${r11}  (${arrow})`);
+  }
+});
